# ── Research-AgenticRAG environment configuration ───────────────────────────
# Copy to .env and fill in:   cp .env.example .env
# The scripts/ auto-load .env (see scripts/_env.py); already-exported shell
# variables win over this file, and blank values are ignored.

# ── LLM backbones ───────────────────────────────────────────────────────────
# Anthropic (primary backbone). You have Haiku 4.5 — run with
#   --provider claude --model claude-haiku-4-5
ANTHROPIC_API_KEY=

# OpenAI (second backbone). For the real OpenAI API, set the key and leave
# OPENAI_BASE_URL unset:
#   --provider openai --model gpt-4o-mini
OPENAI_API_KEY=

# Open model via Ollama (OpenAI-compatible) — llama3.1:8b / qwen2.5:7b /
# mistral:7b / llama3.2:3b. Uncomment both lines and use --provider openai
# --model llama3.1:8b. OPENAI_API_KEY can be any non-empty string for Ollama.
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── HuggingFace datasets (HotpotQA / MuSiQue / FRAMES / CRAG) ────────────────
# Optional but recommended (higher rate limits; required for gated datasets).
HF_TOKEN=

# ── Optional tuning ─────────────────────────────────────────────────────────
# Directory for cached FRAMES Wikipedia page text (default .agenticrag_cache).
# AGENTICRAG_CACHE=.agenticrag_cache
